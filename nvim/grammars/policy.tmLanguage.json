{
	"name": "policy",
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"scopeName": "source.policy",
	"patterns": [
		{
			"include": "#line_comment"
		},
		{
			"include": "#builtin_functions"
		},
		{
			"comment": "Single-quote string literal (character)",
			"name": "string.quoted.single.policy",
			"match": "b?'([^'\\\\]|\\\\(x[0-9A-Fa-f]{2}|[0-2][0-7]{0,2}|3[0-6][0-7]?|37[0-7]?|[4-7][0-7]?|.))'"
		},
		{
			"include": "#string_literal"
		},
		{
			"comment": "Integer literal (decimal)",
			"name": "constant.numeric.integer.decimal.policy",
			"match": "\\b[0-9][0-9_]*\\b"
		},
		{
			"comment": "Boolean literal",
			"name": "constant.language.boolean.policy",
			"match": "\\b(true|false)\\b"
		},
		{
			"comment": "Control keyword",
			"name": "keyword.control.policy",
			"match": "\\b(await|else|if|return|store)\\b"
		},
		{
			"comment": "Keyword",
			"name": "keyword.other.policy",
			"match": "\\b(assert|const|fn|var|policy|volatile|extern)\\b"
		},
		{
			"comment": "Miscellaneous operator",
			"name": "keyword.operator.misc.policy",
			"match": "\\b(::|like|in|is|)\\b"
		},
		{
			"comment": "Logical operators",
			"name": "keyword.other.logical.policy",
			"match": "\\b(and|or|not)\\b"
		},
		{
			"comment": "Comparison operator",
			"name": "keyword.operator.comparison.policy",
			"match": "(==|!=)"
		},
		{
			"comment": "Comparison operator (second group because of regex precedence)",
			"name": "keyword.operator.comparison.policy",
			"match": "(<=|>=|<|>)"
		},
		{
			"include": "#core_types"
		},
		{
			"comment": "Function call",
			"match": "\\b([A-Za-z][A-Za-z0-9_]*|_[A-Za-z0-9_]+)\\s*\\(",
			"captures": {
				"1": {
					"name": "entity.name.function.policy"
				}
			}
		},
		{
			"comment": "Function definition",
			"begin": "\\b(fn)\\s+([A-Za-z][A-Za-z0-9_]*|_[A-Za-z0-9_]+)",
			"end": "[\\{;]",
			"beginCaptures": {
				"1": {
					"name": "keyword.other.fn.policy"
				},
				"2": {
					"name": "entity.name.function.policy"
				}
			},
			"patterns": [
				{
					"include": "#line_comment"
				},
				{
					"include": "#core_types"
				},
				{
					"comment": "Function arguments",
					"match": "\bfn\b",
					"name": "keyword.other.fn.policy"
				}
			]
		},
		{
			"comment": "Type declaration",
			"begin": "\\b(enum|struct)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
			"end": "[\\{\\(;]",
			"beginCaptures": {
				"1": {
					"name": "storage.type.policy"
				},
				"2": {
					"name": "entity.name.type.policy"
				}
			},
			"patterns": [
				{
					"include": "#line_comment"
				},
				{
					"include": "#core_types"
				}
			]
		}
	],
	"repository": {
		"line_comment": {
			"comment": "Single-line comment",
			"name": "comment.line.double-slash.policy",
			"begin": "//",
			"end": "$"
		},
		"escaped_character": {
			"name": "constant.character.escape.policy",
			"match": "\\\\(x[0-9A-Fa-f]{2}|[0-2][0-7]{0,2}|3[0-6][0-7]?|37[0-7]?|[4-7][0-7]?|.)"
		},
		"string_literal": {
			"comment": "Double-quote string literal",
			"name": "string.quoted.double.policy",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"include": "#escaped_character"
				}
			]
		},
		"core_types": {
			"comment": "Built-in/core type",
			"name": "support.type.primitive.policy",
			"match": "\\b(Bool|Int|String|Text|Float|Version)\\b"
		},
		"builtin_functions": {
			"comment": "Builtin function names",
			"name": "support.function.builtin.policy",
			"match": "\\b(any|all|none|empty)\\b"
		},
		"type": {
			"comment": "A type",
			"name": "entity.name.type.policy",
			"match": "\\b([A-Za-z][_A-Za-z0-9]*|_[_A-Za-z0-9]+)\\b"
		}
	}
}